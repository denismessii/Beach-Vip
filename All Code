import { useEffect, useRef, useState } from "react";

type Phase = "start" | "playing" | "denied";

function hasWebGL(): boolean {
  try {
    const canvas = document.createElement("canvas");
    return !!(canvas.getContext("webgl") || canvas.getContext("experimental-webgl"));
  } catch {
    return false;
  }
}

export default function ARGame() {
  const sceneRef = useRef<Element | null>(null);
  const coinContainerRef = useRef<Element | null>(null);

  const [phase, setPhase] = useState<Phase>("start");
  const [xp, setXp] = useState(0);
  const [coins, setCoins] = useState(0);
  const [noDevice, setNoDevice] = useState(false);

  // Build scene on mount
  useEffect(() => {
    const handleError = (e: ErrorEvent) => {
      if (
        e.message?.includes("WebGL") ||
        e.message?.includes("THREE") ||
        e.filename?.includes("aframe")
      ) {
        e.preventDefault();
        e.stopPropagation();
      }
    };
    window.addEventListener("error", handleError, true);

    if (!hasWebGL()) {
      setNoDevice(true);
      return () => window.removeEventListener("error", handleError, true);
    }

    try {
      // Scene
      const scene = document.createElement("a-scene");
      scene.setAttribute("embedded", "");
      scene.setAttribute(
        "arjs",
        "sourceType: webcam; videoTexture: true; debugUIEnabled: false;"
      );
      scene.setAttribute("vr-mode-ui", "enabled: false");
      (scene as HTMLElement).style.cssText =
        "position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;";

      // Coin container
      const container = document.createElement("a-entity");
      container.setAttribute("id", "coin-container");

      // Camera
      const camera = document.createElement("a-camera");
      camera.setAttribute("id", "camera");
      camera.setAttribute("position", "0 0 0");

      scene.appendChild(container);
      scene.appendChild(camera);
      document.body.appendChild(scene);

      sceneRef.current = scene;
      coinContainerRef.current = container;
    } catch {
      setNoDevice(true);
    }

    // resize handler — fix AR canvas on orientation change
    const handleResize = () => {
      const scene = sceneRef.current as any;
      if (scene?.resize) scene.resize();
    };
    window.addEventListener("resize", handleResize);

    return () => {
      window.removeEventListener("error", handleError, true);
      window.removeEventListener("resize", handleResize);
      if (sceneRef.current?.parentNode)
        sceneRef.current.parentNode.removeChild(sceneRef.current);
    };
  }, []);

  function initAR() {
    const DevOri = DeviceOrientationEvent as any;
    if (typeof DevOri.requestPermission === "function") {
      DevOri.requestPermission()
        .then((state: string) => {
          if (state === "granted") startExperience();
          else setPhase("denied");
        })
        .catch(() => setPhase("denied"));
    } else {
      startExperience();
    }
  }

  function startExperience() {
    const container = coinContainerRef.current;
    if (!container) return;

    // Create gold coin
    const coin = document.createElement("a-entity");
    coin.setAttribute("geometry", "primitive: cylinder; radius: 0.3; height: 0.03");
    coin.setAttribute("material", "color: #FFD700; metalness: 0.8; roughness: 0.2");
    coin.setAttribute("position", "0 1.2 -2.5");
    coin.setAttribute("rotation", "90 0 0");
    coin.setAttribute(
      "animation",
      "property: rotation; to: 90 360 0; loop: true; dur: 3000; easing: linear"
    );

    coin.addEventListener("click", () => {
      coin.setAttribute("visible", "false");
      setCoins((prev) => prev + 1);
      setXp((prev) => parseFloat((prev + 0.25).toFixed(2)));
      alert("אספת מטבע! 🥇");
    });

    container.appendChild(coin);
    setPhase("playing");
  }

  // ── No device ─────────────────────────────────────────────────────────────
  if (noDevice) {
    return (
      <div style={{
        minHeight: "100dvh", background: "#000",
        display: "flex", flexDirection: "column",
        alignItems: "center", justifyContent: "center",
        fontFamily: "sans-serif", direction: "rtl",
        padding: "24px", textAlign: "center",
      }}>
        <div style={{ fontSize: "56px", marginBottom: "16px" }}>📱</div>
        <h2 style={{ color: "#FFD700", fontSize: "22px", marginBottom: "12px" }}>נדרש מכשיר נייד</h2>
        <p style={{ color: "#aaa", fontSize: "15px", maxWidth: "300px", lineHeight: 1.6 }}>
          האפליקציה משתמשת במצלמה. פתח מהטלפון הנייד.
        </p>
      </div>
    );
  }

  // ── Denied ────────────────────────────────────────────────────────────────
  if (phase === "denied") {
    return (
      <div style={{
        minHeight: "100dvh", background: "#000",
        display: "flex", flexDirection: "column",
        alignItems: "center", justifyContent: "center",
        fontFamily: "sans-serif", direction: "rtl",
        padding: "24px", textAlign: "center",
      }}>
        <div style={{ fontSize: "56px", marginBottom: "16px" }}>⚠️</div>
        <h2 style={{ color: "#FFD700", fontSize: "22px", marginBottom: "12px" }}>נדרשת הרשאה</h2>
        <p style={{ color: "#aaa", fontSize: "15px", marginBottom: "24px" }}>
          אפשר גישה לחיישנים בהגדרות ונסה שוב.
        </p>
        <button
          onClick={() => setPhase("start")}
          style={{
            background: "#FFD700", color: "#000", border: "none",
            padding: "15px 40px", fontSize: "18px", fontWeight: "bold",
            borderRadius: "50px", cursor: "pointer",
          }}
        >
          נסה שוב
        </button>
      </div>
    );
  }

  // ── Main UI ───────────────────────────────────────────────────────────────
  return (
    <div
      id="ui-layer"
      style={{
        position: "absolute",
        top: 0, left: 0,
        width: "100%", height: "100%",
        pointerEvents: "none",
        zIndex: 100,
        fontFamily: "sans-serif",
        direction: "rtl",
      }}
    >
      {/* Dashboard — always visible */}
      <div
        id="dashboard"
        style={{
          margin: "20px auto", width: "85%",
          background: "rgba(0,0,0,0.85)",
          border: "2px solid #FFD700",
          borderRadius: "15px", padding: "15px",
          color: "white", textAlign: "center",
          pointerEvents: "auto",
        }}
      >
        <div style={{ fontSize: "22px", fontWeight: "bold", color: "#FFD700" }}>הלו ארטיק</div>
        <div style={{ display: "flex", justifyContent: "space-around", marginTop: "10px" }}>
          <div>XP: <span style={{ color: "#FFD700", fontWeight: "bold" }}>{xp.toFixed(2)}</span></div>
          <div>מטבעות: <span style={{ color: "#FFD700", fontWeight: "bold" }}>{coins}</span></div>
