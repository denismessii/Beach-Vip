        async function startNoiseMonitor() {
            const btn = document.getElementById('noise-ctrl-btn');
            try {
                _noiseStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
                _noiseCtx = new (window.AudioContext || window.webkitAudioContext)();
                // Resume context (required after user gesture in modern browsers)
                if (_noiseCtx.state === 'suspended') await _noiseCtx.resume();
                const src = _noiseCtx.createMediaStreamSource(_noiseStream);
                _noiseAnalyser = _noiseCtx.createAnalyser();
                _noiseAnalyser.fftSize = 512;
                _noiseAnalyser.smoothingTimeConstant = 0.8;
                src.connect(_noiseAnalyser);
                _noiseActive = true;
                if (btn) btn.textContent = '⏹ עצור';
                const nsBtn = document.getElementById('noise-submit-btn');
                if (nsBtn) {
