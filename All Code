                const wRes = await fetch(
                    `${APP_CONFIG.WEATHER_API_URL}?latitude=${lat}&longitude=${lng}&current_weather=true&hourly=uv_index&timezone=auto&forecast_days=1`,
                    { signal: AbortSignal.timeout(APP_CONFIG.WEATHER_TIMEOUT_MS) }
