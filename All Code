    .sos-info { background: #fff3e0; color: #e65100; }

    /* ===== UV CARD ===== */
    #uv-card { display: flex; align-items: center; gap: 14px; background: rgba(0,35,68,0.6); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.15); padding: 11px 18px; border-radius: 18px; margin: 10px auto 0; max-width: 380px; color: white; transition: border-color 0.5s ease; }
    .uv-icon { font-size: 24px; flex-shrink: 0; }
    .uv-mid { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
    .uv-number { font-size: 26px; font-weight: 900; line-height: 1; }
    .uv-word { font-size: 9px; color: rgba(255,255,255,0.6); font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-top: 1px; }
    .uv-right-col { flex: 1; }
    .uv-level-tag { display: inline-block; font-size: 10px; font-weight: 800; padding: 2px 9px; border-radius: 99px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
    .uv-rec-text { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.85); margin-bottom: 5px; }
    .uv-scale { height: 4px; background: rgba(255,255,255,0.18); border-radius: 99px; overflow: hidden; }
