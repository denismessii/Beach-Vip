        /**
         * Activates the tan-tone scanner camera feed.
         * First call: requests `getUserMedia({video:{facingMode:'environment'}})`,
         * shows the rear camera live in `#tan-video`, and arms the scan ring overlay.
         * Second call (while `_tanScanning` is true): triggers `analyzeTanSample()`.
         *
         * Graceful degradation: if camera access is denied or unavailable,
         * `analyzeTanSample()` is called immediately with a synthetic mid-brightness
         * value, still delivering a useful SPF recommendation.
         */
        async function startTanScan() {
            const btn = document.getElementById('tan-scan-btn');
            if (_tanScanning) { analyzeTanSample(); return; }
            try {
                _tanStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false });
                const video = document.getElementById('tan-video');
                const ph    = document.getElementById('tan-cam-placeholder');
                const ring  = document.getElementById('tan-scan-ring');
                video.srcObject = _tanStream;
                video.style.display = 'block';
                if (ph) ph.style.display = 'none';
                if (ring) ring.style.display = 'block';
                _tanScanning = true;
                if (btn) btn.textContent = '✨ נתח גוון עור';
            } catch(e) {
                // No camera — simulate scan result
                analyzeTanSample();
            }
        }
        /**
         * Samples the centre 60×60 pixels of the live camera frame and classifies
         * the average brightness into a Fitzpatrick-inspired skin-tone scale
         * (5 bands: 0-75, 75-115, 115-155, 155-195, 195+).
         *
         * Pixel sampling uses a `<canvas>` draw of the `<video>` element.
         * If no live frame is available (camera denied / not yet playing), the
         * function proceeds with the default brightness of 128 (mid-scale) to
         * still deliver a useful SPF recommendation rather than failing silently.
         *
         * The Fitzpatrick mapping is an approximation based on luminance only —
         * it does not account for hue, which would require a full colorimetric
         * analysis. This is sufficient for SPF-guidance purposes.
         *
         * After analysis the camera stream is released via `stopTanCamera()` to
         * prevent the browser from holding the camera permission indicator open.
         */
        function analyzeTanSample() {
            _tanScanning = false;
            const btn = document.getElementById('tan-scan-btn');
            if (btn) btn.textContent = '🔄 סרוק שוב';

            // Try to read actual pixel from video frame
            let detectedColor = null;
            let brightness = 128; // default mid
            try {
                const video = document.getElementById('tan-video');
                if (video && video.videoWidth > 0 && video.readyState >= 2) {
                    const canvas = document.createElement('canvas');
                    const w = video.videoWidth; const h = video.videoHeight;
                    canvas.width = w; canvas.height = h;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(video, 0, 0, w, h);
                    // Sample a 60×60 patch from the center (inside scan ring)
                    const sx = Math.max(0, Math.floor(w/2 - 30));
                    const sy = Math.max(0, Math.floor(h/2 - 30));
