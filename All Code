        /** @type {AudioContext|null} Singleton AudioContext — browsers cap how many can be open simultaneously. */
        let _iceAudioCtx = null;

        /**
         * Plays a short synthetic "ice-click" ASMR cue using the Web Audio API.
         * Reuses a singleton AudioContext to stay within browser limits
         * (Chrome caps concurrent AudioContexts at 6). If the context was
         * suspended by an autoplay policy, `resume()` is called first.
         *
         * Frequency envelope: 2200 Hz → 1500 Hz over 50 ms with exponential
         * decay on gain — mimics the transient of ice cracking in a cold glass.
         *
         * Fails silently via Logger.warn so a missing audio subsystem never
         * blocks cart interactions.
         */
        function playIceASMR() {
            try {
                const AudioContext =
                    window.AudioContext || window.webkitAudioContext;
                if (!AudioContext) return;
                if (!_iceAudioCtx || _iceAudioCtx.state === 'closed') _iceAudioCtx = new AudioContext();
                const ctx = _iceAudioCtx;
                if (ctx.state === 'suspended') ctx.resume();
                const osc1 = ctx.createOscillator();
                const gain1 = ctx.createGain();
                osc1.type = "sine";
                osc1.frequency.setValueAtTime(2200, ctx.currentTime);
                osc1.frequency.exponentialRampToValueAtTime(
                    1500,
                    ctx.currentTime + 0.05,
                );
                gain1.gain.setValueAtTime(0.15, ctx.currentTime);
                gain1.gain.exponentialRampToValueAtTime(
                    0.001,
                    ctx.currentTime + 0.08,
                );
                osc1.connect(gain1);
                gain1.connect(ctx.destination);
                osc1.start();
                osc1.stop(ctx.currentTime + 0.1);
            } catch (e) {
                Logger.warn('AudioContext playback failed', e.message);
            }
        }

        /**
         * Spawns APP_CONFIG.CONFETTI_COUNT confetti particles as absolutely-
         * positioned DOM elements and removes them after CONFETTI_TTL_MS ms.
         *
         * Design note: DOM-based confetti (vs. canvas) is intentional here —
         * it avoids a full-screen canvas overlay that would intercept touch
         * events on the checkout button area during the celebration.
         * 70 particles × 3.5 s lifetime = peak DOM overhead of ~210 nodes,
         * well within browser rendering budgets on mobile.
         */
        function launchGoldConfettiBurst() {
            const colors = APP_CONFIG.CONFETTI_COLORS.slice(); // mutable copy
            for (let i = 0; i < APP_CONFIG.CONFETTI_COUNT; i++) {
                const p = document.createElement("div");
                p.className = "confetti-particle";
                p.style.left = Math.random() * 100 + "vw";
                p.style.backgroundColor =
                    colors[Math.floor(Math.random() * colors.length)];
                p.style.width = Math.random() * 8 + 6 + "px";
                p.style.height = Math.random() * 14 + 6 + "px";
                p.style.animationDuration = Math.random() * 2 + 1.5 + "s";
                p.style.animationDelay = Math.random() * 0.3 + "s";
                document.body.appendChild(p);
                setTimeout(() => p.remove(), APP_CONFIG.CONFETTI_TTL_MS);
            }
        }

        /**
         * Credits loyalty points to the user's balance and evaluates tier promotion.
         * Tier determination uses a linear scan of `tierData` (8 tiers) — O(n) is
         * perfectly acceptable here since n is always ≤ 8.
         * Fires the gold confetti burst as a celebration signal on tier-up.
         *
         * @param {number} additionalPoints - Points to add (must be ≥ 0).
         */
        function updatePointsEngine(additionalPoints) {
            userPoints += additionalPoints;
            let targetIndex = 0;
            for (let i = 0; i < tierData.length; i++) {
                if (userPoints >= tierData[i].min) targetIndex = i;
            }
            if (targetIndex > currentUserTierIndex) {
                launchGoldConfettiBurst();
            }
            currentUserTierIndex = targetIndex;
            rIC(renderPointsUI);
        }

