        function startCompass() {
            if ('DeviceOrientationEvent' in window) {
                const handler = (e) => {
                    const deg = e.alpha ? Math.round(360 - e.alpha) : 0;
                    const arrow = document.getElementById('compass-arrow');
                    const degEl = document.getElementById('compass-deg');
                    if (arrow) arrow.style.transform = 'translateX(-50%) rotate(' + deg + 'deg)';
                    if (degEl) degEl.textContent = deg + '°';
                    // Simulate proximity radar update
                    const dist = 5 + Math.round(Math.random() * 20);
                    const radarDist = document.getElementById('radar-dist');
                    if (radarDist) radarDist.textContent = dist + ' מטר';
                    const blip = document.getElementById('radar-blip');
                    if (blip) { blip.style.top = (20 + Math.random()*60) + '%'; blip.style.left = (20 + Math.random()*60) + '%'; }
                };
                if (typeof DeviceOrientationEvent.requestPermission === 'function') {
                    DeviceOrientationEvent.requestPermission().then(p => {
                        if (p === 'granted') window.addEventListener('deviceorientation', handler);
                    });
                } else {
                    window.addEventListener('deviceorientation', handler);
                }
                _compassWatcher = handler;
            } else {
                // Simulate rotation for non-supported devices
                let angle = 0;
                _compassWatcher = setInterval(() => {
