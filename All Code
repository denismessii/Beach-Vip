        /**
         * Resolves the final unit price for a product + variant combination.
         * Variant-level prices take priority over the product base price, allowing
         * e.g. different bottle sizes to carry different prices without duplicating
         * product records.
         *
         * @param {Object} p          - Product object from the catalogue arrays.
         * @param {string} variantKey - The variant's `vKey` string (e.g. `"v_w500"`),
         *   or an empty string for products with no variant selector.
         * @returns {number} Unit price in AED.
         */
        function getItemPrice(p, variantKey) {
            const cacheKey = `${p.id}_${variantKey || ''}`;
            if (_priceCache.has(cacheKey)) return _priceCache.get(cacheKey);
            let price = p.price;
            if (p.variants && variantKey) {
                const v = p.variants.find(vv => vv.vKey === variantKey);
                if (v && v.price !== undefined) price = v.price;
            }
            _priceCache.set(cacheKey, price);
            return price;
        }

        /**
         * Recomputes cart totals from scratch and syncs every UI element that
         * reflects cart state: product badges, cart bar, nav bubble, and the
         * cart-bar summary text.
         *
         * Design decision: a full recompute on every mutation (rather than
         * incremental deltas) eliminates an entire class of off-by-one bugs
         * that plagued previous incremental approaches. Performance is
         * negligible — the cart never exceeds ~50 distinct keys.
         */
        /**
         * RAF-batching flag — true while a paint frame is already scheduled.
         * Prevents redundant layout recalculation when multiple cart mutations
         * fire within a single 16 ms animation frame (e.g. bundle add writes
         * 4 keys then calls updateCartBar() for each).
         * @type {boolean}
         */
        let _cartUpdatePending = false;

        function updateCartBar() {
            if (_cartUpdatePending) return;
            _cartUpdatePending = true;
