            // Cache key rounded to 3 dp (~111 m precision) so minor GPS
            // jitter on the same beach does not bust the cache.
            const cacheKey = `${lat.toFixed(3)},${lng.toFixed(3)}`;
            const now = Date.now();
            const cached = _weatherCache.get(cacheKey);
            if (cached && (now - cached.ts) < APP_CONFIG.WEATHER_RATE_LIMIT_MS) {
                Logger.debug(`fetchLiveWeather: cache hit for ${cacheKey} (${Math.round((now - cached.ts) / 1000)}s old)`);
                return; // DOM was already updated when the entry was written
            }
