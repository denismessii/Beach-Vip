/**
 * @fileoverview Beach Concierge — Pure Business Logic
 * @description
 *   DOM-free, side-effect-free functions extracted from the main
 *   application controller. Everything in this module is unit-testable
 *   without a browser environment.
 *
 *   These are the canonical implementations. The browser bundle (script.js)
 *   duplicates them inline for legacy compatibility; this module is the
 *   authoritative test target.
 */

// ─────────────────────────────────────────────────────────────────────────────
// CONSTANTS
// ─────────────────────────────────────────────────────────────────────────────

export const BUSINESS_RULES = Object.freeze({
  SERVICE_FEE_AED:              7,
  VIP_SERVICE_FEE_WAIVER_INDEX: 6,
  COUPON_THRESHOLD_AED:         150,
  VALID_DB_MIN:                 20,
  VALID_DB_MAX:                 140,
  SIGNUP_NAME_MAX_LEN:          100,
  CHAT_MESSAGE_MAX_LEN:         500,
  DUBAI_UTC_OFFSET_H:           4,
  DUBAI_ZONE: Object.freeze({ latMin: 25.06, latMax: 25.12, lngMin: 55.10, lngMax: 55.18 }),
});

// ─────────────────────────────────────────────────────────────────────────────
// XSS PREVENTION
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Escapes a value for safe injection into HTML strings (XSS prevention).
 * Must be applied to all user-supplied data before passing to innerHTML.
 *
 * @param {*} value - Any value; non-strings are cast with String().
 * @returns {string} HTML-safe escaped string.
 */
export function sanitize(value) {
  if (value === null || value === undefined) return '';
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#x27;');
}

/**
 * Removes ASCII control characters (0x00–0x1F, 0x7F) from a string.
 * Applied to name fields before storage to prevent log injection and
 * CSV/downstream rendering issues.
 *
 * @param {string} str
 * @returns {string}
 */
export function stripControlChars(str) {
  return String(str || '').replace(/[\x00-\x1F\x7F]/g, '');
}

// ─────────────────────────────────────────────────────────────────────────────
// INPUT VALIDATION
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Validates a phone number against ITU-T E.164 digit-count bounds (7–15).
 * Strips non-digit characters before counting — accepts +, spaces, dashes.
 *
 * @param {string} phone - Raw phone input from the user.
 * @returns {boolean}
 */
export function isValidPhone(phone) {
  const digits = String(phone || '').replace(/\D/g, '');
  return digits.length >= 7 && digits.length <= 15;
}

/**
 * Validates a Beach Concierge grid ID.
 * Format: BEACH- followed by 1–2 uppercase letters and 1–2 digits.
 * Examples: BEACH-A1, BEACH-B12, BEACH-AA3
 *
 * @param {string} id
 * @returns {boolean}
 */
export function isValidGridId(id) {
  return typeof id === 'string' && /^BEACH-[A-Z]{1,2}\d{1,2}$/.test(id);
}

/**
 * Validates a noise reading falls within the physically plausible dB range.
 * 20 dB = near-silence; 140 dB = jet engine / threshold of pain.
 *
 * @param {number} db
 * @returns {boolean}
 */
export function isValidNoiseDb(db) {
  return typeof db === 'number' && !isNaN(db)
    && db >= BUSINESS_RULES.VALID_DB_MIN
    && db <= BUSINESS_RULES.VALID_DB_MAX;
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING ENGINE
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Resolves the unit price for a product/variant combination.
 * Returns the variant price when a matching vKey is found;
 * falls back to the base product price.
 *
 * @param {{ id: number, price: number, variants?: Array<{vKey: string, price: number}> }} product
 * @param {string} [variantKey] - The variant's vKey string (e.g. "v_w500").
 * @returns {number} Unit price in AED.
 */
export function getItemPrice(product, variantKey) {
  if (product.variants && variantKey) {
    const v = product.variants.find(vv => vv.vKey === variantKey);
    if (v && v.price !== undefined) return v.price;
  }
  return product.price;
}

/**
 * Calculates the total item count and merchandise total for a cart snapshot.
 * Pure function — accepts the cart object and a product lookup Map.
 *
 * Cart key format: "{productId}_{variantKey}"
 * Example: "5_v_w500" = product 5, variant v_w500, qty = cart["5_v_w500"]
 *
 * @param {Object.<string, number>} cart - Map of cartKey → quantity
 * @param {Map<number, Object>} productById - Pre-built product lookup Map
 * @returns {{ totalItems: number, totalPrice: number, unknownKeys: string[] }}
 */
export function calculateCartTotal(cart, productById) {
  let totalItems = 0;
  let totalPrice = 0;
  const unknownKeys = [];

  Object.keys(cart).forEach(key => {
    const qty = cart[key];
    if (!qty || qty <= 0) return;
    const parts      = key.split('_');
    const id         = Number(parts[0]);
    const variantKey = parts.slice(1).join('_');
    const product    = productById.get(id);
    if (!product) {
      unknownKeys.push(key);
      return;
    }
    totalItems += qty;
    totalPrice += qty * getItemPrice(product, variantKey);
  });

  return { totalItems, totalPrice, unknownKeys };
}

/**
 * Calculates the service fee for an order.
 * Fee is waived for VIP tier indices ≥ waiveTierIndex (0-based).
 *
 * @param {number} tierIndex        - Current user's tier index (0 = lowest)
 * @param {number} waiveTierIndex   - Tier index at which fee is waived (inclusive)
 * @param {number} serviceFeeAmount - Fee in AED when not waived
 * @returns {number} Fee amount in AED (0 when waived)
 */
export function calculateServiceFee(tierIndex, waiveTierIndex, serviceFeeAmount) {
  return tierIndex >= waiveTierIndex ? 0 : serviceFeeAmount;
}

// ─────────────────────────────────────────────────────────────────────────────
// COUPON ENGINE
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Determines whether a partner coupon strip should be shown.
 *
 * @param {number} cartTotal        - Merchandise total in AED (pre-service-fee)
 * @param {number} [threshold=150]  - Minimum order value to unlock coupon
 * @returns {boolean}
 */
export function shouldShowCoupon(cartTotal, threshold = BUSINESS_RULES.COUPON_THRESHOLD_AED) {
  return cartTotal >= threshold;
}

/**
 * Selects a coupon from the available list deterministically using a
 * pre-supplied random value. This makes the selection unit-testable without
 * mocking Math.random().
 *
 * @param {Array<{brand: string, title: string, code: string}>} coupons
 * @param {number} randomValue - A float in [0, 1) (typically from Math.random())
 * @returns {{ brand: string, title: string, code: string } | null}
 */
export function selectCoupon(coupons, randomValue) {
  if (!coupons || coupons.length === 0) return null;
  return coupons[Math.floor(randomValue * coupons.length)];
}

// ─────────────────────────────────────────────────────────────────────────────
// RATE LIMITER FACTORY
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Creates a sliding-window client-side rate limiter.
 * The limiter is injectable with a clock function for deterministic testing.
 *
 * @param {number} maxAttempts  - Max calls within the window
 * @param {number} windowMs     - Sliding window duration in milliseconds
 * @param {() => number} [clock] - Clock function (default: Date.now)
 * @returns {{ check: (action: string) => boolean, reset: (action: string) => void }}
 */
export function createRateLimiter(maxAttempts, windowMs, clock = Date.now) {
  const _windows = new Map();
  return {
    check(action) {
      const now  = clock();
      const prev = (_windows.get(action) || []).filter(t => now - t < windowMs);
      if (prev.length >= maxAttempts) return false;
      prev.push(now);
      _windows.set(action, prev);
      return true;
    },
    reset(action) {
      _windows.delete(action);
    },
  };
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION HELPERS
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Returns true when the given coordinates fall within the Dubai beach
 * delivery zone (JBR → Kite Beach coastal strip).
 *
 * @param {number} lat
 * @param {number} lng
 * @returns {boolean}
 */
export function isInDubaiZone(lat, lng) {
  const z = BUSINESS_RULES.DUBAI_ZONE;
  return lat >= z.latMin && lat <= z.latMax && lng >= z.lngMin && lng <= z.lngMax;
}


