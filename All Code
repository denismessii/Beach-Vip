        function drawNoiseMeter() {
            if (!_noiseActive || !_noiseAnalyser) return;
            const data = new Uint8Array(_noiseAnalyser.frequencyBinCount);
            _noiseAnalyser.getByteTimeDomainData(data);
            // RMS-based dB calculation for more accurate reading
            let sum = 0;
            for (let i = 0; i < data.length; i++) {
                const val = (data[i] - 128) / 128;
                sum += val * val;
            }
            const rms = Math.sqrt(sum / data.length);
            const db = rms > 0.00001 ? Math.round(20 + 60 * Math.min(1, rms * 8)) : 25;
            updateNoiseMeterUI(db);
