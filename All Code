        let progressStep = 0;
        let _progressTimers = [];
        /**
         * Starts the animated order-progress indicator and advances it through
         * five steps on a pre-defined schedule defined in APP_CONFIG.ORDER_PROGRESS_DELAYS.
         *
         * Safety: clears any in-flight timers from a previous order before
         * scheduling new ones — prevents two orders racing to update the same
         * progress dots simultaneously if the user re-orders quickly.
         *
         * Step schedule (illustrative): Placed(0s) → Confirmed(12s) → Preparing(30s)
         *   → On its way(70s) → Delivered(120s).
         */
        function startOrderProgress() {
            _progressTimers.forEach(t => clearTimeout(t));
            _progressTimers = [];
            progressStep = 0;
            document.getElementById('order-progress-section').style.display = 'block';
            updateProgressDots();
            const delays = APP_CONFIG.ORDER_PROGRESS_DELAYS;
            delays.forEach((d, i) => {
                _progressTimers.push(setTimeout(() => { progressStep = i; updateProgressDots(); }, d));
            });
        }
        function updateProgressDots() {
            const totalSteps = 5;
            for (let i = 0; i < totalSteps; i++) {
                const dot = document.getElementById(`pdot-${i}`);
                if (!dot) continue;
                dot.classList.remove('done', 'active');
                if (i < progressStep) dot.classList.add('done');
                else if (i === progressStep) dot.classList.add('active');
            }
            const lineEl = document.getElementById('prog-line');
            if (lineEl) lineEl.style.width = `${(progressStep / (totalSteps - 1)) * 84}%`;
        }

