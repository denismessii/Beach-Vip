                const temp = Math.round(wData.current_weather.temperature);
                const windCode = wData.current_weather.weathercode;
                const icon = windCode === 0 ? '☀️' : windCode < 3 ? '⛅' : windCode < 50 ? '🌤️' : '🌧️';

