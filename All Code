    #uv-card.uv-moderate .uv-level-tag { background: #eab308; color: #1a1a1a; }
    #uv-card.uv-moderate .uv-scale-fill { background: #eab308; }
    #uv-card.uv-high { border-color: rgba(249,115,22,0.4); }
    #uv-card.uv-high .uv-level-tag { background: #f97316; color: white; }
    #uv-card.uv-high .uv-scale-fill { background: #f97316; }
    #uv-card.uv-extreme { border-color: rgba(168,85,247,0.5); }
    #uv-card.uv-extreme .uv-level-tag { background: #a855f7; color: white; }
    #uv-card.uv-extreme .uv-scale-fill { background: #a855f7; }

