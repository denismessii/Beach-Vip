// ─────────────────────────────────────────────────────────────────────────────
// 8. calculateServiceFee()
// ─────────────────────────────────────────────────────────────────────────────

describe('calculateServiceFee()', () => {
  const { SERVICE_FEE_AED, VIP_SERVICE_FEE_WAIVER_INDEX } = BUSINESS_RULES;

  it('charges full fee at tier 0 (new member)', () => {
    expect(calculateServiceFee(0, VIP_SERVICE_FEE_WAIVER_INDEX, SERVICE_FEE_AED)).toBe(7);
  });

  it('charges full fee at tier 5 (one below waiver threshold)', () => {
    expect(calculateServiceFee(5, VIP_SERVICE_FEE_WAIVER_INDEX, SERVICE_FEE_AED)).toBe(7);
  });

  it('waives fee at exact waiver tier (tier 6)', () => {
    expect(calculateServiceFee(6, VIP_SERVICE_FEE_WAIVER_INDEX, SERVICE_FEE_AED)).toBe(0);
  });

  it('waives fee above waiver tier (tier 7)', () => {
    expect(calculateServiceFee(7, VIP_SERVICE_FEE_WAIVER_INDEX, SERVICE_FEE_AED)).toBe(0);
  });

  it('returns custom fee amount when supplied', () => {
    expect(calculateServiceFee(0, 3, 15)).toBe(15);
  });

  it('returns 0 for any tier when waiver threshold is 0', () => {
    expect(calculateServiceFee(0, 0, SERVICE_FEE_AED)).toBe(0);
  });
});

// ─────────────────────────────────────────────────────────────────────────────
// 9. shouldShowCoupon()
// ─────────────────────────────────────────────────────────────────────────────

describe('shouldShowCoupon()', () => {
  it('returns false below threshold (149 AED)', () => {
    expect(shouldShowCoupon(149)).toBe(false);
  });

  it('returns true at exact threshold (150 AED)', () => {
    expect(shouldShowCoupon(150)).toBe(true);
  });

  it('returns true above threshold (300 AED)', () => {
    expect(shouldShowCoupon(300)).toBe(true);
  });

  it('returns false for empty cart (0 AED)', () => {
    expect(shouldShowCoupon(0)).toBe(false);
  });

  it('respects custom threshold', () => {
    expect(shouldShowCoupon(99, 100)).toBe(false);
    expect(shouldShowCoupon(100, 100)).toBe(true);
  });
});

