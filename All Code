        /* ── Swipe-up to enter: full-screen gesture on welcome overlay ── */
        let _swipeTouchStartY = 0;
        let _swipeTouchStartX = 0;
        let _swipeActive = false;
        const ENTRY_SWIPE_MIN = 70; // px upward to trigger entry

        function initSwipeEngine() {
            const overlay = document.getElementById("welcome-overlay");
            if (!overlay) return;
            overlay.addEventListener("touchstart", _swUpStart, { passive: true });
            overlay.addEventListener("touchmove",  _swUpMove,  { passive: false });
            overlay.addEventListener("touchend",   _swUpEnd,   { passive: true });
            // Desktop: mouse drag upward also works
            overlay.addEventListener("mousedown", _swUpStart);
            window.addEventListener("mousemove",  _swUpMove);
            window.addEventListener("mouseup",    _swUpEnd);
        }

        function _swUpStart(e) {
            const p = e.touches ? e.touches[0] : e;
            _swipeTouchStartY = p.clientY;
            _swipeTouchStartX = p.clientX;
            _swipeActive = true;
        }
        function _swUpMove(e) {
            if (!_swipeActive) return;
            const p = e.touches ? e.touches[0] : e;
            const dy = _swipeTouchStartY - p.clientY; // positive = upward
            const dx = Math.abs(p.clientX - _swipeTouchStartX);
            // Only treat as vertical swipe if mostly upward
            if (dy > 20 && dx < dy && e.cancelable) e.preventDefault();
        }
        function _swUpEnd(e) {
            if (!_swipeActive) return;
            _swipeActive = false;
            const p = e.changedTouches ? e.changedTouches[0] : e;
            const dy = _swipeTouchStartY - p.clientY;
            const dx = Math.abs(p.clientX - _swipeTouchStartX);
            if (dy >= ENTRY_SWIPE_MIN && dx < dy) {
                enterAppDirectly();
            }
        }

