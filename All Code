            if (db < 50)      { zone = currentLang === 'he' ? '🟢 אזור שקט — מצוין' : '🟢 Quiet Zone'; color = '#22c55e'; }
            else if (db < 65) { zone = currentLang === 'he' ? '🟡 רעש בינוני' : '🟡 Moderate Noise'; color = '#facc15'; }
            else if (db < 80) { zone = currentLang === 'he' ? '🟠 רועש — שקול להתרחק' : '🟠 Loud — move away'; color = '#f97316'; }
            else               { zone = currentLang === 'he' ? '🔴 רעש גבוה מאוד!' : '🔴 Very Loud!'; color = '#ef4444'; }
            if (zoneEl) { zoneEl.textContent = zone; zoneEl.style.color = color; }
            // Animate bars
            const bars = document.querySelectorAll('.noise-bar-item');
            bars.forEach((bar, i) => {
                const h = 4 + Math.round(Math.random() * (db / 3));
                bar.style.height = Math.min(40, h) + 'px';
                bar.style.background = color;
            });
        }

