        function stopNoiseMonitor() {
            _noiseActive = false;
            if (_noiseRAF) { clearInterval(_noiseRAF); _noiseRAF = null; }
            if (_noiseStream) { _noiseStream.getTracks().forEach(t => t.stop()); _noiseStream = null; }
            if (_noiseCtx) { _noiseCtx.close(); _noiseCtx = null; }
            const btn = document.getElementById('noise-ctrl-btn');
            if (btn) btn.textContent = '🎙️ התחל מדידה';
