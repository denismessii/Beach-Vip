            Object.keys(cart).forEach((key) => {
                const parts = key.split("_");
                const id = parts[0];
                const variantKey = parts.slice(1).join("_");
                const qty = cart[key];
                if (qty > 0) {
                    totalItems += qty;
                    const p = _productById.get(Number(id));
                    if (p) {
                        totalPrice += qty * getItemPrice(p, variantKey);
                        const b = document.getElementById(`badge-${id}`);
                        if (b) {
                            b.textContent =
                                parseInt(b.textContent || 0) + qty;
                            b.classList.remove("hidden");
                        }
                    }
                }
            });

            const cb = document.getElementById("cart-bar");
            const navBubble = document.getElementById("navCartBubble");
            if (totalItems > 0) {
                cb.classList.add("visible");
                document.getElementById("cart-total").textContent =
                    `${totalPrice} AED`;
                document.getElementById("cart-count").textContent =
                    totalItems;
                document.getElementById("cartBarText").innerHTML =
                    `${dict.cartBarText} <strong id="cart-total">${totalPrice} AED</strong>`;
                navBubble.textContent = totalItems;
                navBubble.style.display = "block";
            } else {
                cb.classList.remove("visible");
                navBubble.style.display = "none";
            }
        }

