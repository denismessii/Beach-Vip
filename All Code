            // user switches location twice within 2 s (rapid GPS jitter).
            if (now - _lastWeatherFetchTs < 2000) {
                Logger.debug('fetchLiveWeather: global debounce, skipping');
                return;
            }
            _lastWeatherFetchTs = now;
