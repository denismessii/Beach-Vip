        // ── Global swipe state (one active drag at a time) ──
        let _swipeDragging = false;
        let _swipeEl = null, _swipeBgAdd = null, _swipeBgRemove = null;
        let _swipeStartX = 0, _swipeStartY = 0, _swipeKey = "";
        let _swipeLocked = false; // locked to horizontal

        const SWIPE_THRESHOLD = 70;
        const SWIPE_MAX = 100;

        function _swipeOnStart(e, rowEl, bgAdd, bgRemove, cartKey) {
            if (_swipeDragging) return;
            const t = e.touches ? e.touches[0] : e;
            _swipeStartX = t.clientX;
            _swipeStartY = t.clientY;
            _swipeDragging = true;
            _swipeLocked = false;
            _swipeEl = rowEl;
            _swipeBgAdd = bgAdd;
            _swipeBgRemove = bgRemove;
            _swipeKey = cartKey;
            rowEl.style.transition = "none";
            rowEl.style.willChange = "transform";
        }

        function _swipeOnMove(e) {
            if (!_swipeDragging || !_swipeEl) return;
            const t = e.touches ? e.touches[0] : e;
            const dx = t.clientX - _swipeStartX;
            const dy = t.clientY - _swipeStartY;

            // First movement: decide axis
            if (!_swipeLocked) {
                if (Math.abs(dy) > Math.abs(dx) + 5) {
                    // vertical scroll wins — abort
                    _swipeDragging = false;
                    _swipeEl.style.transition = "transform 0.25s cubic-bezier(0.16,1,0.3,1)";
                    _swipeEl.style.transform = "translateX(0px)";
                    return;
                }
                if (Math.abs(dx) > 5) _swipeLocked = true;
            }
            if (!_swipeLocked) return;

            if (e.cancelable) e.preventDefault();

            const clamped = Math.max(-SWIPE_MAX, Math.min(SWIPE_MAX, dx));
            _swipeEl.style.transform = "translateX(" + clamped + "px)";

            const ratio = Math.min(1, Math.abs(clamped) / SWIPE_THRESHOLD);
            if (clamped > 0) {
                _swipeBgAdd.style.opacity = ratio;
                _swipeBgRemove.style.opacity = 0;
            } else if (clamped < 0) {
                _swipeBgRemove.style.opacity = ratio;
                _swipeBgAdd.style.opacity = 0;
                const icon = _swipeBgRemove.querySelector(".swipe-hint-icon");
                if (icon) icon.textContent = (cart[_swipeKey] === 1) ? "🗑️" : "➖";
            } else {
                _swipeBgAdd.style.opacity = 0;
                _swipeBgRemove.style.opacity = 0;
            }
        }

        function _swipeOnEnd(e) {
            if (!_swipeDragging || !_swipeEl) return;
            _swipeDragging = false;

            const t = e.changedTouches ? e.changedTouches[0] : e;
            const dx = t.clientX - _swipeStartX;

            const rowEl   = _swipeEl;
            const bgAdd   = _swipeBgAdd;
            const bgRem   = _swipeBgRemove;
            const cartKey = _swipeKey;

            _swipeEl = null; _swipeBgAdd = null; _swipeBgRemove = null;

            bgAdd.style.opacity = 0;
            bgRem.style.opacity = 0;

            function snapAndAct(toX, action) {
                rowEl.style.transition = "transform 0.28s cubic-bezier(0.16,1,0.3,1)";
                rowEl.style.transform  = "translateX(" + toX + "px)";
                setTimeout(action, toX === 0 ? 180 : 280);
            }

            if (!_swipeLocked || (Math.abs(dx) < SWIPE_THRESHOLD)) {
                // snap back
                snapAndAct(0, () => {});
            } else if (dx >= SWIPE_THRESHOLD) {
                // ── ADD ──
                snapAndAct(0, () => {
                    cart[cartKey] = (cart[cartKey] || 0) + 1;
                    updateCartBar();
                    renderOrderList();
                });
            } else if (dx <= -SWIPE_THRESHOLD) {
                if (cart[cartKey] > 1) {
                    // ── DECREMENT ──
                    snapAndAct(0, () => {
                        cart[cartKey]--;
                        updateCartBar();
                        renderOrderList();
                    });
                } else {
                    // ── REMOVE (fly out) ──
                    snapAndAct(-380, () => {
                        delete cart[cartKey];
                        updateCartBar();
                        renderOrderList();
                    });
                }
            }
        }

        // Attach once to window
        window.addEventListener("mousemove", _swipeOnMove, { passive: false });
        window.addEventListener("mouseup",   _swipeOnEnd,  { passive: true });
        window.addEventListener("touchmove", _swipeOnMove, { passive: false });
        window.addEventListener("touchend",  _swipeOnEnd,  { passive: true });

        // ── renderOrderList with Swipe-to-Manage ──
        /**
         * Renders the checkout item list and computes the final order total.
         * Applies service fee logic (waived for VIP tier ≥ APP_CONFIG.VIP_SERVICE_FEE_WAIVER_INDEX),
         * and appends the upsell recommendation strip at the bottom of the list.
         * Each row is wired with left/right swipe gestures (add/remove quantity).
         *
         * Called by: `openCheckout()`, swipe gesture handlers.
         */
        function renderOrderList() {
            let total = 0;
            const all = [...products, ...vipProducts, ...experiences];
            const dict = translations[currentLang];
            const container = document.getElementById("order-list");
            container.innerHTML = "";

            const _catLabels = {
                menu:  {he:'🍦 תפריט',ar:'🍦 القائمة',ru:'🍦 Меню',es:'🍦 Menú',fr:'🍦 Menu',en:'🍦 Menu'},
                equip: {he:'🛍️ ציוד',ar:'🛍️ معدات',ru:'🛍️ Снаряжение',es:'🛍️ Equipo',fr:'🛍️ Équipement',en:'🛍️ Equipment'},
