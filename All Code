         * Cross-Site Scripting (XSS). Must be applied to ALL data that
         * originates outside the trusted product catalogue (user input,
         * localStorage, external API text, etc.) before passing to innerHTML.
         *
         * Why: localStorage is same-origin but user-supplied text stored
         * there (e.g. Beach Social messages) could contain `<script>` tags
         * or event-handler attributes if a different code-path ever wrote
         * raw user input without sanitisation.
         *
         * @param {*} value - Any value; non-strings are cast with String().
         * @returns {string} HTML-safe escaped string.
         */
        function sanitize(value) {
            if (value === null || value === undefined) return '';
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#x27;');
