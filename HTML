        <div style="font-size:12px;font-weight:700;color:var(--muted);margin-bottom:8px;">בחר מה לשלוח:</div>
        <div class="drink-picker" id="drink-picker">
            <div class="drink-chip" onclick="selectDrink(this,'💧 מים')">💧 מים</div>
            <div class="drink-chip" onclick="selectDrink(this,'🥤 ענרגי')">🥤 ענרגי</div>
            <div class="drink-chip" onclick="selectDrink(this,'🍦 גלידה')">🍦 גלידה</div>
            <div class="drink-chip" onclick="selectDrink(this,'🧃 מיץ')">🧃 מיץ</div>
            <div class="drink-chip" onclick="selectDrink(this,'☕ קפה')">☕ קפה</div>
        </div>
        <button class="send-confirm-btn" onclick="confirmSendDrink()">✨ שלח עכשיו — 15 AED</button>
        <button onclick="closeSendDrink()" style="width:100%;padding:11px;background:none;border:none;color:var(--muted);font-size:13px;font-weight:700;cursor:pointer;margin-top:8px;">ביטול</button>
    </div>
</div>

<!-- GAME FINDER MODAL -->
<div id="game-finder-modal">
    <div class="game-sheet">
        <div style="width:40px;height:4px;background:#dee2e8;border-radius:99px;margin:0 auto 18px;"></div>
        <div style="padding:0 16px 16px;font-size:18px;font-weight:900;color:var(--navy);">🏐 Pick-up Games</div>
        <div class="game-card">
            <div class="game-icon">🏓</div>
            <div class="game-info">
                <div class="game-title">מטקות — כולם מוזמנים</div>
                <div class="game-meta">📍 ליד BEACH-D4 · 👥 3/6 משתתפים · עכשיו</div>
            </div>
            <button class="game-join-btn" onclick="joinGame(this)">הצטרף</button>
        </div>
        <div class="game-card">
            <div class="game-icon">🏐</div>
            <div class="game-info">
                <div class="game-title">כדורעף חופים</div>
                <div class="game-meta">📍 ליד BEACH-B2 · 👥 4/8 משתתפים · 17:00</div>
            </div>
            <button class="game-join-btn" onclick="joinGame(this)">הצטרף</button>
        </div>
        <div class="game-card">
            <div class="game-icon">🏄</div>
            <div class="game-info">
                <div class="game-title">גלישה קבוצתית</div>
                <div class="game-meta">📍 BEACH-F1 · 👥 2/5 · 16:30 · ₪ חינם</div>
            </div>
            <button class="game-join-btn" onclick="joinGame(this)">הצטרף</button>
        </div>
        <div class="game-card">
            <div class="game-icon">🃏</div>
            <div class="game-info">
                <div class="game-title">קלפים בצל — ברידג' / פוקר</div>
                <div class="game-meta">📍 BEACH-A8 · 👥 2/4 · כל היום</div>
            </div>
            <button class="game-join-btn" onclick="joinGame(this)">הצטרף</button>
        </div>
        <div class="game-host-strip" onclick="hostGame()">+ ארגן משחק שלך</div>
        <div style="height:40px;"></div>
    </div>
</div>

<!-- GOLDEN ROBOT MODAL -->
<div id="golden-robot-modal">
    <div class="robot-box">
        <span class="robot-emoji">🤖</span>
        <div class="robot-title">מצא את הרובוט הזהוב!</div>
        <div class="robot-clue" id="robot-clue">הרובוט הזהוב נחבא בתא גריד מיוחד. הגע לשם ראשון וקבל <strong style="color:var(--gold);">100 AED</strong> קרדיט!</div>
        <div class="robot-grid-target" id="robot-target-grid">BEACH-G3</div>
        <div class="robot-prize-wrap" id="robot-prize-found">
            <div style="font-size:24px;margin-bottom:8px;">🎉</div>
            <div style="font-size:16px;font-weight:900;color:#22c55e;">כל הכבוד! מצאת אותו!</div>
            <div style="font-size:13px;color:#15803d;margin-top:4px;">100 AED קרדיט יתווספו לחשבונך</div>
        </div>
        <button class="robot-checkin-btn" id="robot-checkin-btn" onclick="robotCheckIn()">📍 אני כאן! Check-in</button>
        <div class="robot-close-link" onclick="closeGoldenRobot()">סגור</div>
    </div>
</div>

<!-- NOISE MONITOR MODAL -->
<div id="noise-modal">
    <div class="noise-box">
        <div class="noise-title">📊 מד רעש חוף</div>
        <div class="noise-sub">מדוד את רמת הרעש באזורך ומצא אזור שקט</div>
        <div class="noise-meter-wrap">
            <svg class="noise-arc-svg" viewBox="0 0 160 90">
                <path d="M 10 88 A 70 70 0 0 1 150 88" fill="none" stroke="#e2e8f0" stroke-width="12" stroke-linecap="round"/>
                <path d="M 10 88 A 70 70 0 0 1 57 22" fill="none" stroke="#22c55e" stroke-width="12" stroke-linecap="round"/>
                <path d="M 57 22 A 70 70 0 0 1 103 22" fill="none" stroke="#facc15" stroke-width="12" stroke-linecap="round"/>
                <path d="M 103 22 A 70 70 0 0 1 150 88" fill="none" stroke="#ef4444" stroke-width="12" stroke-linecap="round"/>
            </svg>
            <div class="noise-needle" id="noise-needle"></div>
        </div>
        <div id="noise-db-val">-- dB</div>
        <div id="noise-zone-label" style="color:var(--muted);">לחץ "התחל" למדידה</div>
        <div class="noise-bars" id="noise-bars">
            <div class="noise-bar-item" style="height:8px;"></div><div class="noise-bar-item" style="height:12px;"></div>
            <div class="noise-bar-item" style="height:8px;"></div><div class="noise-bar-item" style="height:16px;"></div>
            <div class="noise-bar-item" style="height:10px;"></div><div class="noise-bar-item" style="height:8px;"></div>
            <div class="noise-bar-item" style="height:14px;"></div><div class="noise-bar-item" style="height:8px;"></div>
        </div>
        <button class="noise-ctrl-btn" id="noise-ctrl-btn" onclick="toggleNoiseMonitor()">🎙️ התחל מדידה</button>
        <button class="noise-submit-btn" id="noise-submit-btn" onclick="submitNoiseReading()" style="display:none;">📍 שתף רעש — BEACH-??</button>
        <button id="noise-map-toggle-btn" onclick="toggleNoiseMap()" class="noise-map-toggle-btn">🗺️ מפת רעש החוף</button>
        <div id="noise-map-area" style="display:none;margin-top:12px;"></div>
        <button class="noise-close-btn" onclick="closeNoiseModal()">סגור</button>
    </div>
</div>

<!-- TAN SCANNER MODAL -->
<div id="tan-scanner-modal">
    <div class="tan-sheet">
        <div style="width:40px;height:4px;background:#dee2e8;border-radius:99px;margin:0 auto 18px;"></div>
        <div style="font-size:18px;font-weight:900;color:var(--navy);margin-bottom:6px;">🌿 AI Tan Scanner</div>
        <div style="font-size:13px;color:var(--muted);margin-bottom:16px;">סרוק את גוון עורך לקבלת המלצות מותאמות אישית</div>
        <div class="tan-camera-preview" id="tan-cam-preview">
            <video id="tan-video" autoplay playsinline muted></video>
            <span class="tan-cam-placeholder" id="tan-cam-placeholder">📸</span>
            <div class="tan-scan-ring" id="tan-scan-ring" style="display:none;"></div>
        </div>
        <button class="tan-scan-btn" id="tan-scan-btn" onclick="startTanScan()">📸 הפעל מצלמה וסרוק</button>
        <div class="tan-result-area" id="tan-result-area">
            <div class="tan-result-title">✨ תוצאת הסריקה</div>
            <div class="tan-tone-display" id="tan-tone-bar"></div>
            <div class="tan-tone-label" id="tan-tone-label"></div>
            <div style="font-size:12px;font-weight:700;color:var(--muted);margin-bottom:8px;">המלצות מוצרים:</div>
            <div class="tan-recs" id="tan-recs"></div>
        </div>
        <button onclick="closeTanScanner()" style="width:100%;padding:12px;background:none;border:none;color:var(--muted);font-size:13px;font-weight:700;cursor:pointer;margin-top:12px;">סגור</button>
    </div>
</div>

</body>

</html>
