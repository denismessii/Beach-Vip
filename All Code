            const cr = cb ? cb.getBoundingClientRect() : { left: window.innerWidth / 2, top: window.innerHeight - 90, width: 0, height: 0 };
            dot.style.setProperty('--tx', ((cr.left + cr.width / 2) - cx) + 'px');
            dot.style.setProperty('--ty', ((cr.top + cr.height / 2) - cy) + 'px');
