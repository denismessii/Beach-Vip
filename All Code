        let _voiceListenTimer = null;
        function startVoiceListening() {
            const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SR) return;
            if (_voiceRecognition) { try { _voiceRecognition.stop(); } catch(e) {} }
            // Clear any previous timeout
            if (_voiceListenTimer) { clearTimeout(_voiceListenTimer); _voiceListenTimer = null; }
            _voiceRecognition = new SR();
            _voiceRecognition.continuous = false;
            _voiceRecognition.interimResults = true;
            const langMap = { he:'he-IL', ar:'ar-AE', ru:'ru-RU', en:'en-US', es:'es-ES', fr:'fr-FR' };
            _voiceRecognition.lang = langMap[currentLang] || 'he-IL';
            haptic(40);
            _setVoiceState('listening');
            _voiceRecognition.onresult = (e) => {
                let transcript = '';
                for (let i = e.resultIndex; i < e.results.length; i++) transcript += e.results[i][0].transcript;
                document.getElementById('voice-transcript-box').textContent = transcript;
                if (e.results[e.results.length - 1].isFinal) {
                    if (_voiceListenTimer) { clearTimeout(_voiceListenTimer); _voiceListenTimer = null; }
                    _processVoiceTranscript(transcript);
                }
            };
            _voiceRecognition.onerror = (e) => {
                _setVoiceState('error');
                haptic([50,50,50]);
                document.getElementById('voice-transcript-box').textContent =
                    currentLang === 'he' ? '\u05e9\u05d2\u05d9\u05d0\u05d4: ' + e.error : 'Error: ' + e.error;
            };
            _voiceRecognition.onend = () => {
                const fab = document.getElementById('voice-fab');
                if (fab && fab.classList.contains('listening')) _setVoiceState('idle');
            };
            _voiceRecognition.start();
            // Hard timeout: if no final result after 8 seconds, force-process transcript
            _voiceListenTimer = setTimeout(() => {
                if (!_voiceRecognition) return;
                const transcriptEl = document.getElementById('voice-transcript-box');
                const t = transcriptEl ? transcriptEl.textContent.trim() : '';
                if (t && t.length > 1) {
                    try { _voiceRecognition.stop(); } catch(e) {}
                    _voiceRecognition = null;
                    _processVoiceTranscript(t);
                } else {
                    try { _voiceRecognition.stop(); } catch(e) {}
                    _voiceRecognition = null;
                    _setVoiceState('idle');
                }
                _voiceListenTimer = null;
            }, 8000);
        }

        function _processVoiceTranscript(transcript) {
            _setVoiceState('processing');
            if (_voiceRecognition) { try { _voiceRecognition.stop(); } catch(e) {} _voiceRecognition = null; }
            setTimeout(() => {
                const items = _parseVoiceOrder(transcript);
                if (!items.length) {
                    _setVoiceState('error');
                    haptic([50,50,50]);
                    _voiceSpeak(currentLang === 'he' ? '\u05e1\u05dc\u05d9\u05d7\u05d4, \u05dc\u05d0 \u05de\u05e6\u05d0\u05ea\u05d9 \u05d0\u05ea \u05d6\u05d4 \u05d1\u05ea\u05e4\u05e8\u05d9\u05d8. \u05e0\u05e1\u05d4 \u05e9\u05d5\u05d1.' :
                                  'Sorry, I couldn\u2019t find that in the menu. Please try again.');
                    document.getElementById('voice-transcript-box').textContent =
                        currentLang === 'he' ? '\u274C \u05dc\u05d0 \u05d6\u05d5\u05d4\u05d4 \u05de\u05d5\u05e6\u05e8. \u05e0\u05e1\u05d4: "\u05e7\u05d5\u05dc\u05d4 \u05d0\u05d7\u05ea" \u05d0\u05d5 "\u05e9\u05e0\u05d9 \u05d0\u05e8\u05d8\u05d9\u05e7\u05d9\u05dd"' :
                        '\u274C No products detected. Try: "one cola" or "two ice pops"';
                    document.querySelector('.voice-btn-row').style.display = 'none';
                    return;
                }
                _voicePendingItems = items;
                _setVoiceState('success');
                haptic(60);
                document.getElementById('voice-confirm-chips').innerHTML = items.map(it =>
                    `<span class="voice-item-chip">\u00D7 ${it.qty} ${it.label}</span>`).join('');
                document.querySelector('.voice-confirm-list').classList.add('visible');
                document.querySelector('.voice-btn-row').style.display = 'flex';
                const names = items.map(it => `${it.qty} ${it.label}`).join(', ');
                _voiceSpeak(currentLang === 'he' ? `\u05d4\u05d5\u05e1\u05e4\u05ea\u05d9 ${names}. \u05d6\u05d4 \u05d1\u05e1\u05d3\u05e8?` :
                             currentLang === 'ar' ? `\u0623\u0636\u0641\u062a ${names}. \u0647\u0644 \u0647\u0630\u0627 \u0635\u062d\u064a\u062d\u061f` :
                             `Added ${names}. Is that correct?`);
                document.getElementById('voice-transcript-box').textContent = '\u201C' + transcript + '\u201D';
            }, 600);
        }

