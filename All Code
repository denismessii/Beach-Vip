--- FILE: .github/workflows/ci.yml ---

name: CI — Lint, Type-check & Unit Tests

on:
  push:
    branches: ["**"]
  pull_request:
    branches: [main, master]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ─────────────────────────────────────────────────────────────────────────
  # JOB 1: Type-check all workspace packages
  # ─────────────────────────────────────────────────────────────────────────
  typecheck:
    name: Type-check (TypeScript)
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 24
          cache: pnpm

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Run type-check
        run: pnpm run typecheck

  # ─────────────────────────────────────────────────────────────────────────
  # JOB 2: Unit tests for core business logic
  # ─────────────────────────────────────────────────────────────────────────
  unit-tests:
    name: Unit Tests (Vitest)
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 24
          cache: pnpm

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Run unit tests with coverage
        run: pnpm --filter @workspace/simple-website run test:coverage

      - name: Upload coverage report
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: coverage-report
          path: artifacts/simple-website/coverage/
          retention-days: 14

  # ─────────────────────────────────────────────────────────────────────────
  # JOB 3: Build verification (confirms Vite can bundle without errors)
  # Note: build requires PORT + BASE_PATH env vars, so we stub them here
  # ─────────────────────────────────────────────────────────────────────────
  build-check:
    name: Build Verification (Vite)
    runs-on: ubuntu-latest
    needs: [typecheck, unit-tests]
    env:
      PORT: 3000
      BASE_PATH: /simple-website/
      NODE_ENV: production
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 10

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 24
          cache: pnpm

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Build Beach Concierge
        run: pnpm --filter @workspace/simple-website run build

      - name: Verify dist output
        run: |
          test -d artifacts/simple-website/dist/public || (echo "dist/public not found" && exit 1)
          test -f artifacts/simple-website/dist/public/index.html || (echo "index.html missing" && exit 1)
          echo "✅ Build output verified"


