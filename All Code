                        `${APP_CONFIG.GEOCODE_API_URL}?format=json&lat=${lat}&lon=${lng}&accept-language=${currentLang === 'he' ? 'he' : 'en'}`,
                        { signal: AbortSignal.timeout(APP_CONFIG.GEOCODE_TIMEOUT_MS) }
                    );
                    const gData = await gRes.json();
                    cityName = gData.address.city || gData.address.town || gData.address.village
                               || gData.address.county || gData.address.state || cityName;
                } catch(e) {
                    Logger.warn('fetchLiveWeather: reverse geocode failed (non-critical)', e.message);
                }

                const weatherEl = document.getElementById('weatherDubai');
                if (weatherEl) weatherEl.textContent = `${icon} ${cityName}: ${temp}°C`;

                // 3. UV index for current hour + card styling
                try {
