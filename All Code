            '\u05d0\u05d7\u05d3':1,'\u05d0\u05d7\u05ea':1,'\u05e9\u05e0\u05d9\u05d9\u05dd':2,'\u05e9\u05ea\u05d9\u05d9\u05dd':2,'\u05e9\u05e0\u05d9':2,'\u05e9\u05ea\u05d9':2,'\u05e9\u05dc\u05d5\u05e9\u05d4':3,'\u05e9\u05dc\u05d5\u05e9':3,'\u05d0\u05e8\u05d1\u05e2\u05d4':4,'\u05d0\u05e8\u05d1\u05e2':4,'\u05d7\u05de\u05d9\u05e9\u05d4':5,'\u05d7\u05de\u05e9':5,
            '\u043e\u0434\u0438\u043d':1,'\u043e\u0434\u043d\u0443':1,'\u0434\u0432\u0430':2,'\u0434\u0432\u0435':2,'\u0442\u0440\u0438':3,'\u0447\u0435\u0442\u044b\u0440\u0435':4,'\u043f\u044f\u0442\u044c':5,'\u0448\u0435\u0441\u0442\u044c':6,'\u0441\u0435\u043c\u044c':7,
            '\u0648\u0627\u062d\u062f':1,'\u0627\u062b\u0646\u0627\u0646':2,'\u0627\u062b\u0646\u064a\u0646':2,'\u062b\u0644\u0627\u062b\u0629':3,'\u0623\u0631\u0628\u0639\u0629':4,'\u062e\u0645\u0633\u0629':5,
            un:1,une:1,deux:2,trois:3,quatre:4,cinq:5,six:6,sept:7,huit:8,
            uno:1,una:1,dos:2,tres:3,cuatro:4,cinco:5,seis:6,siete:7,
        };

        function _buildVoiceCatalog() {
            const all = [...products, ...vipProducts, ...experiences];
            return all.map(p => {
                const keywords = new Set();
                Object.keys(translations).forEach(lang => {
                    const n = translations[lang][p.nameKey];
                    if (n) n.toLowerCase().split(/[\s,\/\-]+/).forEach(w => { if (w.length > 2) keywords.add(w); });
                });
                (VOICE_ALIASES[p.id] || []).forEach(a => a.toLowerCase().split(/\s+/).forEach(w => keywords.add(w)));
                return {
                    id: p.id,
                    defaultVKey: p.variants ? p.variants[0].vKey : 'v_box',
                    keywords: [...keywords],
                    label: (translations['en'][p.nameKey] || translations['he'][p.nameKey] || p.nameKey),
                };
            });
        }

        function _parseVoiceOrder(text) {
            const catalog = _buildVoiceCatalog();
            const lower = text.toLowerCase().trim();
            const tokens = lower.split(/[\s,،.!?؟\-\/]+/).filter(Boolean);

            // Resolve a token to a quantity number (strips common Hebrew conjunctive prefixes)
            const resolveNum = (t) => {
                if (!t) return null;
                const n = parseInt(t);
                if (!isNaN(n) && n > 0 && n < 50) return n;
                // Try raw
                if (NUM_WORDS[t] != null) return NUM_WORDS[t];
                // Strip Hebrew/Arabic prefix letters (ו=and, ב=in, ל=to, מ=from, כ=like, ה=the)
                const stripped = t.replace(/^[וּבּלּמּכּהּוּבלמכה]/, '');
                if (stripped !== t && NUM_WORDS[stripped] != null) return NUM_WORDS[stripped];
                return null;
            };

            // Find nearest quantity within ±2 tokens of pos (prefers closest first)
            const findQtyNear = (pos) => {
                for (let d = 1; d <= 2; d++) {
                    // Check left then right at each distance
                    for (const delta of [-d, d]) {
                        const q = resolveNum(tokens[pos + delta]);
                        if (q !== null) return q;
                    }
                }
                return null; // not found nearby
            };

            // Find the quantity CLOSEST to pos (used as fallback when nothing nearby)
            const closestQty = (pos) => {
                let best = null, bestDist = Infinity;
                tokens.forEach((t, i) => {
                    const q = resolveNum(t);
                    if (q !== null && Math.abs(i - pos) < bestDist) {
                        bestDist = Math.abs(i - pos);
                        best = q;
                    }
                });
                return best || 1;
            };

            const results = [];
            const seen = new Set();

            catalog.forEach(item => {
                let qty = 1, matchedKw = null;

                let kwTokIdx = -1;

                // Pass 1: exact substring match
                for (const kw of item.keywords) {
                    if (kw.length < 2) continue;
                    if (lower.includes(kw)) {
                        matchedKw = kw;
                        kwTokIdx = tokens.findIndex(t => t.includes(kw) || (kw.includes(t) && t.length >= 3));
                        break;
                    }
                }

                // Pass 2: prefix match (handles speech recognition word-ending cuts)
                if (!matchedKw) {
                    for (const kw of item.keywords) {
                        if (kw.length < 4) continue;
                        const kwPfx = kw.slice(0, Math.floor(kw.length * 0.75));
                        const ti = tokens.findIndex(t => t.startsWith(kwPfx) || (kwPfx.startsWith(t) && t.length >= 4));
                        if (ti >= 0) { matchedKw = kw; kwTokIdx = ti; break; }
                    }
                }

                if (matchedKw && !seen.has(item.id)) {
                    seen.add(item.id);
                    // Try nearby window first, then fall back to CLOSEST number in utterance
                    qty = (kwTokIdx >= 0 ? findQtyNear(kwTokIdx) : null) ?? closestQty(kwTokIdx >= 0 ? kwTokIdx : 0);
                    results.push({ id: item.id, vKey: item.defaultVKey, qty, label: item.label });
                }
            });
            return results;
        }

        function _voiceSpeak(text) {
            if (!window.speechSynthesis) return;
            speechSynthesis.cancel();
            const utt = new SpeechSynthesisUtterance(text);
            utt.rate = 0.95; utt.pitch = 1.05;
            speechSynthesis.speak(utt);
        }

