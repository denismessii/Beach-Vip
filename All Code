        function dismissLocationModal() {
            document
                .getElementById("location-modal-overlay")
                .classList.add("hidden");

            // Swipe engine ready immediately — user can swipe to enter while GPS resolves
            initSwipeEngine();

            if (navigator.geolocation) {
                // Helper: process a successful position fix
                function _handleGpsPosition(position) {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    window._weatherFromGps = true;
                    if (window._weatherGpsFallback) { clearTimeout(window._weatherGpsFallback); window._weatherGpsFallback = null; }
                    fetchLiveWeather(lat, lng);
                    updateGridBadge(lat, lng, position.coords.accuracy);
                    // km distance from Dubai Marina
                    const cosLat = Math.cos(lat * Math.PI / 180);
                    const dkm = Math.sqrt(
                        Math.pow((lat - 25.079) * 111.32, 2) +
                        Math.pow((lng - 55.139) * 111.32 * cosLat, 2)
                    );
                    if (dkm < 18) {
                        isUserInDubaiBeachZone = true;
                        initMap(lat, lng);
                        deliveryLocation = `GPS: ${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                        const ta = document.getElementById('id-sign'); if (ta) ta.value = deliveryLocation;
                        document.getElementById('manual-zone-picker').style.display = 'none';
                        const sub = document.getElementById('compact-location-sub');
                        if (sub) sub.textContent = '📡 GPS פעיל — חוף דובאי';
                    } else {
                        isUserInDubaiBeachZone = false;
                        initMap(lat, lng);
                        document.getElementById('manual-zone-picker').style.display = 'none';
                        const sub = document.getElementById('compact-location-sub');
                        if (sub) sub.textContent = '📍 ' + (currentLang === 'he' ? 'מחוץ לאזור דובאי' : 'Outside Dubai Zone');
                    }
                    applyServiceStateUI();
                }
                // Helper: fall back gracefully (IP geo or Dubai default)
                async function _handleGpsFailure() {
                    isUserInDubaiBeachZone = false;
                    // Try IP geo for weather accuracy
                    try {
                        const r = await fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(5000) });
                        const d = await r.json();
                        if (d.latitude && d.longitude) {
                            fetchLiveWeather(d.latitude, d.longitude);
                            initMap(d.latitude, d.longitude);
                        } else { throw new Error('no coords'); }
                    } catch(e) {
                        fetchLiveWeather(25.079, 55.139);
                        initMap(25.079, 55.139);
                    }
                    document.getElementById('manual-zone-picker').style.display = 'block';
                    applyServiceStateUI();
                }
                // Step 1: try high-accuracy GPS
                navigator.geolocation.getCurrentPosition(
                    _handleGpsPosition,
                    () => {
                        // Step 2: high-accuracy failed — retry with low accuracy (faster on some devices)
                        navigator.geolocation.getCurrentPosition(
                            _handleGpsPosition,
                            _handleGpsFailure,
                            { enableHighAccuracy: false, timeout: 8000, maximumAge: 30000 }
                        );
                    },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
                );
            } else {
                isUserInDubaiBeachZone = false;
                fetchLiveWeather(25.079, 55.139);
                initMap(25.079, 55.139);
                document.getElementById('manual-zone-picker').style.display = 'block';
            }
        }

