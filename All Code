// 10. selectCoupon()
// ─────────────────────────────────────────────────────────────────────────────

describe('selectCoupon()', () => {
  it('returns null for empty coupon list', () => {
    expect(selectCoupon([], 0.5)).toBeNull();
  });

  it('returns null for null coupon list', () => {
    expect(selectCoupon(null, 0.5)).toBeNull();
  });

  it('always returns the first coupon when randomValue = 0', () => {
    expect(selectCoupon(PARTNER_COUPONS, 0).code).toBe('BEACH15');
  });

  it('returns the correct coupon for randomValue = 0.33 (index 0)', () => {
    expect(selectCoupon(PARTNER_COUPONS, 0.33).code).toBe('BEACH15');
  });

  it('returns the correct coupon for randomValue = 0.5 (index 1)', () => {
    expect(selectCoupon(PARTNER_COUPONS, 0.5).code).toBe('VIP20');
  });

  it('returns the correct coupon for randomValue approaching 1 (last index)', () => {
    expect(selectCoupon(PARTNER_COUPONS, 0.99).code).toBe('AQUA10');
  });

  it('always returns the single coupon regardless of randomValue', () => {
    const single = [PARTNER_COUPONS[0]];
    expect(selectCoupon(single, 0).code).toBe('BEACH15');
    expect(selectCoupon(single, 0.99).code).toBe('BEACH15');
  });
});

// ─────────────────────────────────────────────────────────────────────────────
// 11. createRateLimiter()
// ─────────────────────────────────────────────────────────────────────────────

describe('createRateLimiter()', () => {
  let time;
  let limiter;

  beforeEach(() => {
    time = 0;
    limiter = createRateLimiter(3, 60_000, () => time);
  });

  it('allows calls up to the limit', () => {
    expect(limiter.check('signup')).toBe(true);
    expect(limiter.check('signup')).toBe(true);
    expect(limiter.check('signup')).toBe(true);
  });

  it('blocks the call that exceeds the limit', () => {
    limiter.check('signup');
    limiter.check('signup');
    limiter.check('signup');
    expect(limiter.check('signup')).toBe(false);
  });

  it('allows calls again after the window slides past old entries', () => {
    limiter.check('signup');
    limiter.check('signup');
    limiter.check('signup');
    time = 61_000; // slide window past all previous calls
    expect(limiter.check('signup')).toBe(true);
  });

  it('tracks separate windows per action key', () => {
    limiter.check('signup');
    limiter.check('signup');
    limiter.check('signup');
    // 'chat' has its own window — should still be allowed
    expect(limiter.check('chat')).toBe(true);
  });

  it('reset() clears the window for the specified action', () => {
    limiter.check('signup');
    limiter.check('signup');
    limiter.check('signup');
    limiter.reset('signup');
    expect(limiter.check('signup')).toBe(true);
  });

  it('does not block calls that fall within a partial window', () => {
    time = 0;    limiter.check('signup'); // t=0
    time = 20_000; limiter.check('signup'); // t=20s
    time = 40_000; limiter.check('signup'); // t=40s
    // At t=65s: the t=0 call has expired, only t=20s and t=40s remain → 2 in window
    time = 65_000;
    expect(limiter.check('signup')).toBe(true);
  });
});

// ─────────────────────────────────────────────────────────────────────────────
// 12. isInDubaiZone()
// ─────────────────────────────────────────────────────────────────────────────

describe('isInDubaiZone()', () => {
  it('accepts JBR Beach coordinates', () => {
    expect(isInDubaiZone(25.078, 25.141)).toBe(false); // lng out of range — checking lat is fine
    expect(isInDubaiZone(25.079, 55.139)).toBe(true);
  });

  it('accepts coordinates at zone boundary (latMin, lngMin)', () => {
    expect(isInDubaiZone(25.06, 55.10)).toBe(true);
  });

  it('accepts coordinates at zone boundary (latMax, lngMax)', () => {
    expect(isInDubaiZone(25.12, 55.18)).toBe(true);
  });

  it('rejects coordinates outside zone (Abu Dhabi)', () => {
    expect(isInDubaiZone(24.45, 54.37)).toBe(false);
  });

  it('rejects coordinates north of zone', () => {
    expect(isInDubaiZone(25.13, 55.14)).toBe(false);
  });

  it('rejects coordinates east of zone', () => {
    expect(isInDubaiZone(25.09, 55.20)).toBe(false);
  });
});


