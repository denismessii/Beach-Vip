            courierMarker = L.marker([currentLat, currentLng], {
                icon: courierIcon,
            }).addTo(map);
            if (_courierInterval) clearInterval(_courierInterval);
            _courierInterval = setInterval(() => {
                if (!courierMarker) { clearInterval(_courierInterval); _courierInterval = null; return; }
                currentLat -= (currentLat - userLoc.lat) * 0.08;
                currentLng -= (currentLng - userLoc.lng) * 0.08;
