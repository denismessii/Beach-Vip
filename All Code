    /* ===== BUNDLE DEALS ===== */
    .bundle-grid { display: flex; flex-direction: column; gap: 10px; padding: 0 16px; margin-bottom: 4px; }
    .bundle-card { background: var(--white); border-radius: 20px; padding: 14px; display: flex; align-items: center; gap: 12px; box-shadow: 0 4px 14px rgba(0,35,68,0.07); border: 1px solid rgba(214,175,55,0.25); }
    .bundle-icon { font-size: 28px; width: 50px; height: 50px; background: rgba(214,175,55,0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .bundle-info { flex: 1; min-width: 0; }
    .bundle-name { font-weight: 800; font-size: 13px; color: var(--navy); margin-bottom: 2px; }
    .bundle-desc { font-size: 11px; color: var(--muted); margin-bottom: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bundle-pricing { display: flex; align-items: center; gap: 7px; }
    .bundle-price { font-size: 15px; font-weight: 900; color: var(--navy); }
    .bundle-original { font-size: 11px; color: var(--muted); text-decoration: line-through; }
    .bundle-save { font-size: 10px; font-weight: 800; color: #16a34a; background: rgba(34,197,94,0.1); padding: 2px 7px; border-radius: 99px; }
    .btn-bundle-add { background: var(--gold); color: var(--navy); border: none; padding: 10px 14px; border-radius: 12px; font-size: 12px; font-weight: 800; cursor: pointer; white-space: nowrap; flex-shrink: 0; transition: opacity 0.2s; }

    /* ===== ORDER HISTORY ===== */
    #order-history-section { display: none; margin: 0 16px 14px; background: var(--bg-light); border-radius: 18px; padding: 14px 16px; border: 1px solid rgba(0,35,68,0.05); }
    .history-title { font-size: 12px; font-weight: 800; color: var(--navy); text-transform: uppercase; margin-bottom: 10px; }
    .history-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(0,35,68,0.06); font-size: 13px; }
    .history-row:last-child { border-bottom: none; }
    .history-row .hname { font-weight: 600; color: var(--navy); }
    .history-row .hdate { font-size: 11px; color: var(--muted); }
    .btn-reorder { background: var(--navy); color: white; border: none; padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; }

    /* ===== ORDER PROGRESS ===== */
    #order-progress-section { display: none; margin: 0 16px 14px; background: var(--white); border-radius: 18px; padding: 14px 16px; box-shadow: 0 4px 12px rgba(0,35,68,0.07); border: 1px solid rgba(0,35,68,0.05); }
    .prog-title { font-size: 12px; font-weight: 800; color: var(--navy); text-transform: uppercase; margin-bottom: 12px; }
    .prog-steps { display: flex; justify-content: space-between; position: relative; }
    .prog-steps::before { content: ''; position: absolute; top: 14px; right: 8%; left: 8%; height: 3px; background: #e2e8f0; z-index: 0; }
    .prog-line { position: absolute; top: 14px; right: 8%; height: 3px; background: var(--gold); z-index: 1; width: 0%; transition: width 1.2s ease; }
    html[dir="ltr"] .prog-line { right: auto; left: 8%; }
    .prog-dot { width: 30px; height: 30px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; z-index: 2; position: relative; transition: background 0.4s; }
    .prog-dot.done { background: #2e7d32; color: white; }
    .prog-dot.active { background: var(--gold); color: var(--navy); }
    .prog-labels { display: flex; justify-content: space-between; font-size: 9px; color: var(--muted); margin-top: 6px; font-weight: 600; }

    /* ===== MANUAL ZONE PICKER ===== */
    #manual-zone-picker { display: none; padding: 10px 8px 4px; }
    #manual-zone-picker p { font-size: 11px; color: var(--muted); font-weight: 600; margin: 0 0 8px; }
    .zone-opt { display: block; width: 100%; padding: 9px 12px; margin-bottom: 6px; background: var(--bg-light); border: 1.5px solid #cbd5e1; border-radius: 10px; font-size: 12px; font-weight: 600; text-align: right; cursor: pointer; font-family: inherit; }
    html[dir="ltr"] .zone-opt { text-align: left; }
    .zone-opt.picked { border-color: var(--gold); background: rgba(214,175,55,0.1); }

    /* ===== CHECKOUT: GROUP ORDER + WALLET ===== */
    .checkout-extras { padding: 0 22px; margin-bottom: 8px; }
    .extras-block { background: var(--bg-light); border-radius: 14px; padding: 12px 14px; margin-bottom: 10px; }
    .extras-label { font-size: 11px; font-weight: 800; color: var(--navy); text-transform: uppercase; margin-bottom: 10px; display: block; }
    .split-row { display: flex; align-items: center; gap: 10px; }
    .split-btn { width: 34px; height: 34px; border-radius: 50%; border: 2px solid var(--navy); background: white; font-size: 18px; font-weight: 700; cursor: pointer; color: var(--navy); font-family: inherit; }
    #split-num { font-size: 17px; font-weight: 800; min-width: 24px; text-align: center; }
    #per-person-amt { font-size: 12px; color: var(--muted); margin-top: 6px; font-weight: 600; }
    .pay-opts { display: flex; gap: 8px; flex-wrap: wrap; }
    .pay-opt { flex: 1; padding: 10px 6px; border-radius: 12px; border: 1.5px solid #cbd5e1; background: white; font-size: 12px; font-weight: 700; cursor: pointer; min-width: 72px; text-align: center; font-family: inherit; }
    .pay-opt.chosen { border-color: var(--gold); background: rgba(214,175,55,0.12); color: var(--navy); }
    #wallet-info { display: none; background: linear-gradient(135deg, var(--navy), #003d70); color: white; border-radius: 12px; padding: 10px 14px; margin-top: 8px; }
    #wallet-info .wbal { font-size: 20px; font-weight: 900; }
    #wallet-info .wlbl { font-size: 10px; opacity: 0.75; }

    /* ===== SKELETON LOADING ===== */
    @keyframes shimmer {
        0%   { background-position: -600px 0; }
        100% { background-position:  600px 0; }
    }
    .skeleton-card {
        background: var(--card-bg);
        border-radius: 18px;
        overflow: hidden;
        min-height: 220px;
    }
    .skel-line {
        background: linear-gradient(90deg, var(--bg-light) 25%, rgba(190,205,230,0.55) 50%, var(--bg-light) 75%);
        background-size: 600px 100%;
        animation: shimmer 1.3s ease-in-out infinite;
        border-radius: 6px;
    }
    .skel-img  { height: 136px; width: 100%; border-radius: 0; }
    .skel-h    { height: 13px; width: 62%; margin: 14px 16px 8px; }
    .skel-p    { height: 11px; width: 36%; margin: 0 16px 10px; }
    .skel-btn  { height: 36px; width: calc(100% - 32px); margin: 0 16px; border-radius: 10px; }

    /* ===== BOUNCE ADD BUTTON ===== */
    @keyframes btn-bounce {
        0%   { transform: scale(1); }
        25%  { transform: scale(0.83); }
        60%  { transform: scale(1.2); }
        80%  { transform: scale(0.95); }
        100% { transform: scale(1); }
    }
    .btn-add.bounce-pop { animation: btn-bounce 0.42s cubic-bezier(0.36,0.07,0.19,0.97) both; }

    /* ===== VOICE FAB ===== */
    #voice-fab {
        position: fixed;
        bottom: 92px;
        left: 20px;
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a3a6b 0%, #0055bb 100%);
        color: #fff;
        font-size: 22px;
        border: none;
        box-shadow: 0 4px 18px rgba(0,85,187,0.45);
        z-index: 2000;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    #voice-fab.app-ready { display: flex; }
    #voice-fab.listening {
        background: linear-gradient(135deg, #aa0000 0%, #ff3b30 100%);
        box-shadow: 0 4px 22px rgba(255,59,48,0.55);
        animation: pulse-mic 0.9s ease-in-out infinite;
    }
    @keyframes pulse-mic {
        0%, 100% { transform: scale(1); }
        50%       { transform: scale(1.13); }
    }

    /* ===== VOICE MODAL ===== */
    #voice-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,18,55,0.65);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 8500;
        display: none;
        align-items: flex-end;
        justify-content: center;
    }
    #voice-modal-overlay.open { display: flex; }
    .voice-sheet {
        background: var(--card-bg);
        width: 100%;
        max-width: 480px;
        border-radius: 28px 28px 0 0;
        padding: 22px 22px 44px;
        animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
    }
    .voice-ring {
        width: 76px; height: 76px;
        border-radius: 50%;
        background: var(--bg-light);
        display: flex; align-items: center; justify-content: center;
        font-size: 34px;
        margin: 0 auto 12px;
        transition: background 0.3s;
    }
    .voice-ring.listening  { background: #ffe0de; animation: pulse-mic 0.9s infinite; }
    .voice-ring.processing { background: #fff8d4; }
    .voice-ring.success    { background: #d6f5de; }
    .voice-ring.error      { background: #ffe0de; }
    #voice-status-text {
        text-align: center; font-size: 14px; font-weight: 700;
        color: var(--muted); margin-bottom: 10px; min-height: 20px;
    }
    #voice-transcript-box {
        min-height: 42px;
        background: var(--bg-light);
        border-radius: 12px;
        padding: 11px 14px;
        font-size: 15px; color: var(--text); font-weight: 600;
        text-align: center; margin-bottom: 12px;
        word-break: break-word; direction: auto;
    }
    .voice-confirm-list {
        background: var(--bg-light);
        border-radius: 14px; padding: 12px 14px; margin-bottom: 14px; display: none;
    }
    .voice-confirm-list.visible { display: block; }
    .voice-confirm-title {
        font-size: 11px; font-weight: 800; text-transform: uppercase;
        letter-spacing: 0.5px; color: var(--gold-dk); margin-bottom: 8px;
    }
    .voice-item-chip {
        display: inline-flex; align-items: center; gap: 5px;
        background: var(--navy); color: #fff;
        border-radius: 20px; padding: 5px 13px;
        font-size: 13px; font-weight: 700; margin: 3px;
    }
    .voice-btn-row { display: flex; gap: 10px; margin-top: 14px; }
    .voice-btn-confirm {
        flex: 1; padding: 14px;
        background: linear-gradient(135deg, var(--navy), #0066cc);
        color: #fff; border: none; border-radius: 14px;
        font-size: 15px; font-weight: 800; cursor: pointer;
    }
    .voice-btn-cancel {
        padding: 14px 20px; background: var(--bg-light);
        color: var(--text); border: none; border-radius: 14px;
        font-size: 15px; font-weight: 700; cursor: pointer;
    }
    #voice-mic-btn {
        width: 100%; padding: 13px;
        background: linear-gradient(135deg, #1a3a6b, #0055bb);
        color: #fff; border: none; border-radius: 14px;
        font-size: 16px; font-weight: 800; cursor: pointer;
        margin-bottom: 10px;
    }

    /* ===== CART UPSELL IN CHECKOUT ===== */
    .cart-upsell-block { border-top: 1px solid var(--border); padding: 14px 0 4px; margin: 6px 0; }
    .cart-upsell-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: var(--gold-dk); margin-bottom: 10px; }
    .cart-upsell-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .c-upsell-chip {
        background: var(--navy); color: #fff; border: none;
        border-radius: 22px; padding: 7px 14px; font-size: 12px; font-weight: 700;
        cursor: pointer; transition: transform 0.15s, background 0.2s;
    }
    .c-upsell-chip:active { transform: scale(0.93); }
    .c-upsell-chip.added  { background: #28a745; }

    /* ===== OUT-OF-ZONE NOTIFY BUTTON ===== */
    .out-zone-notify-btn {
        display: inline-flex; align-items: center; gap: 6px;
        margin-top: 14px; padding: 11px 22px;
        background: var(--gold); color: var(--navy) !important;
        border: none; border-radius: 24px;
        font-size: 14px; font-weight: 900; cursor: pointer;
        box-shadow: 0 4px 18px rgba(0,0,0,0.35);
        transition: transform 0.15s, box-shadow 0.15s;
        text-decoration: none;
        animation: notifyPulse 2.5s ease-in-out infinite;
    }
    @keyframes notifyPulse {
        0%, 100% { box-shadow: 0 4px 18px rgba(0,0,0,0.35); }
        50% { box-shadow: 0 4px 28px rgba(212,175,55,0.7); }
    }
    .out-zone-notify-btn:active { transform: scale(0.95); box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
    .out-zone-notify-btn.subscribed {
        background: #28a745; color: #fff !important;
        animation: none; box-shadow: 0 3px 12px rgba(40,167,69,0.4);
    }
    .out-zone-notify-btn:disabled { opacity: 0.85; cursor: default; animation: none; }

    /* ===== ORDER SUCCESS MODAL ===== */
    #order-success-overlay {
        position: fixed; inset: 0;
        background: rgba(0,18,55,0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 9400;
        display: none; align-items: center; justify-content: center;
    }
    #order-success-overlay.open { display: flex; }
    .success-modal-box {
        background: var(--card-bg); border-radius: 28px;
        padding: 36px 28px 32px; max-width: 330px; width: 90%;
        text-align: center; animation: popIn 0.45s cubic-bezier(0.16,1,0.3,1);
    }
    @keyframes popIn {
        from { transform: scale(0.68); opacity: 0; }
        to   { transform: scale(1);    opacity: 1; }
    }
    .success-emoji { font-size: 58px; display: block; margin-bottom: 14px; }
    .success-title { font-size: 22px; font-weight: 900; color: var(--navy); margin-bottom: 8px; }
    .success-sub   { font-size: 14px; color: var(--muted); font-weight: 600; margin-bottom: 24px; line-height: 1.55; }
    .success-close-btn {
        width: 100%; padding: 14px;
        background: linear-gradient(135deg, var(--navy), #0066cc);
        color: #fff; border: none; border-radius: 14px;
        font-size: 16px; font-weight: 800; cursor: pointer;
    }
/* ============================================================
   GRID MATRIX BADGE
   ============================================================ */
.grid-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--navy); color: var(--gold);
    border: 1.5px solid rgba(212,175,55,0.5);
    border-radius: 22px; padding: 7px 16px;
    font-size: 13px; font-weight: 900;
    font-family: 'Courier New', monospace; letter-spacing: 0.8px;
    margin: 4px 16px 14px; box-shadow: 0 3px 12px rgba(0,0,0,0.18);
    cursor: default; user-select: none;
}
.grid-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink:0; animation: gpulse 1.6s ease-in-out infinite; }
@keyframes gpulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(1.4)} }
.grid-badge-val { color: var(--gold); }
.grid-badge-acc { font-size:10px; color:#94a3b8; font-family:inherit; letter-spacing:0; margin-left:2px; }

/* ============================================================
   MODE FAB (Driver/Client toggle)
   ============================================================ */
#mode-fab {
    position: fixed; bottom: 178px; left: 16px; z-index: 1100;
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--navy); color: var(--gold);
    border: 2px solid var(--gold); font-size: 20px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    transition: all 0.25s; opacity: 0; pointer-events: none;
}
#mode-fab.app-ready { opacity: 1; pointer-events: all; }
#mode-fab.driver { background: var(--gold); color: var(--navy); }

/* ============================================================
   DRIVER MODE FULL-SCREEN PANEL
   ============================================================ */
#driver-panel {
    display: none; position: fixed; inset: 0; z-index: 3000;
    background: #000d1f; flex-direction: column; align-items: center;
    overflow-y: auto; padding-bottom: 40px;
}
#driver-panel.open { display: flex; }
.driver-topbar {
    width: 100%; max-width: 480px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 54px 20px 20px;
}
.driver-title { font-size: 20px; font-weight: 900; color: var(--gold); letter-spacing: 1px; }
.driver-close { background: none; border: 1.5px solid rgba(212,175,55,0.4); color: var(--gold); border-radius: 12px; padding: 6px 14px; font-size: 13px; font-weight: 700; cursor: pointer; }
.driver-grid-badge { font-family: 'Courier New', monospace; font-size: 22px; font-weight: 900; color: var(--gold); background: rgba(212,175,55,0.08); border: 1px solid rgba(212,175,55,0.3); border-radius: 14px; padding: 8px 20px; margin-bottom: 24px; }

.compass-wrap { width: 180px; height: 180px; position: relative; margin: 0 auto 28px; }
.compass-outer { width:100%; height:100%; border-radius:50%; border: 2px solid rgba(212,175,55,0.25); background: radial-gradient(circle, #001233 60%, #000d1f 100%); display:flex; align-items:center; justify-content:center; box-shadow:0 0 40px rgba(212,175,55,0.15); position:relative; }
.compass-arrow { position:absolute; width:4px; height:76px; bottom:50%; left:50%; transform:translateX(-50%) rotate(0deg); transform-origin: bottom center; background:linear-gradient(to top,#e53935 50%,#fff 50%); border-radius:4px 4px 0 0; transition:transform 0.4s ease; }
.compass-labels { position:absolute; inset:0; }
.compass-labels span { position:absolute; font-size:12px; font-weight:900; color:var(--gold); }
.compass-labels .cn { top:8px; left:50%; transform:translateX(-50%); }
.compass-labels .cs { bottom:8px; left:50%; transform:translateX(-50%); }
.compass-labels .cw { left:8px; top:50%; transform:translateY(-50%); }
.compass-labels .ce { right:8px; top:50%; transform:translateY(-50%); }
.compass-deg { font-size:18px; font-weight:900; color:#fff; }

.radar-wrap { width:140px; height:140px; position:relative; margin:0 auto 24px; }
.radar-outer { width:100%; height:100%; border-radius:50%; border:2px solid rgba(34,197,94,0.3); background:radial-gradient(#002200 0%,#000d1f 100%); overflow:hidden; position:relative; }
.radar-sweep { position:absolute; inset:0; background:conic-gradient(from 0deg, transparent 0%, rgba(34,197,94,0.55) 18%, transparent 18%); animation:rspin 2s linear infinite; }
@keyframes rspin { to { transform:rotate(360deg); } }
.radar-blip { position:absolute; width:9px; height:9px; border-radius:50%; background:#22c55e; box-shadow:0 0 8px #22c55e; animation:rblip 1.2s ease-in-out infinite; }
@keyframes rblip { 0%,100%{opacity:1} 50%{opacity:0.2} }
.radar-dist { text-align:center; font-size:14px; font-weight:800; color:#22c55e; margin-top:8px; }

.driver-orders-title { font-size:14px; font-weight:800; color:#94a3b8; text-transform:uppercase; letter-spacing:1px; margin:0 0 12px; width:100%; max-width:480px; padding:0 20px; }
.driver-order-card { width:100%; max-width:480px; padding:0 20px 12px; }
.driver-card-inner { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:18px; padding:16px; }
.doc-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.doc-grid { font-size:17px; font-weight:900; color:var(--gold); font-family:'Courier New',monospace; }
.doc-status { font-size:11px; font-weight:800; background:rgba(34,197,94,0.15); color:#22c55e; padding:4px 10px; border-radius:10px; }
.doc-items { font-size:13px; color:#94a3b8; margin-bottom:12px; line-height:1.5; }
.doc-nav-btn { width:100%; padding:12px; border:none; border-radius:16px; background:var(--gold); color:var(--navy); font-size:14px; font-weight:900; cursor:pointer; }

/* ============================================================
   HYDRATION TRACKER
   ============================================================ */
.hydration-bar {
    margin: 0 16px 14px; padding: 11px 16px;
    background: linear-gradient(135deg,rgba(59,130,246,0.08) 0%,rgba(96,165,250,0.12) 100%);
    border: 1px solid rgba(59,130,246,0.22); border-radius: 16px;
    display: flex; align-items: center; gap: 12px; cursor: pointer;
    transition: transform 0.15s;
}
.hydration-bar:active { transform: scale(0.98); }
.hydration-icon { font-size: 22px; flex-shrink:0; }
.hydration-info { flex:1; }
.hydration-title { font-size:12px; font-weight:800; color:#3b82f6; }
.hydration-sub { font-size:11px; color:var(--muted); }
.hydration-track { height:5px; background:rgba(0,0,0,0.07); border-radius:99px; overflow:hidden; margin-top:5px; }
.hydration-fill { height:100%; background:linear-gradient(90deg,#60a5fa,#2563eb); border-radius:99px; transition:width 1s ease; }
.hydration-bar.alert { border-color:rgba(239,68,68,0.55); animation:hpulse 2s ease-in-out infinite; }
@keyframes hpulse { 0%,100%{background:linear-gradient(135deg,rgba(239,68,68,0.05) 0%,rgba(248,113,113,0.08) 100%)} 50%{background:linear-gradient(135deg,rgba(239,68,68,0.12) 0%,rgba(248,113,113,0.16) 100%)} }

/* ============================================================
   DISCOVER TAB (6th nav item)
   ============================================================ */
#discover-section { display:none; padding:16px 0 90px; }
#discover-section.visible { display:block; }
.discover-section-title { font-size:12px; font-weight:800; color:var(--muted); text-transform:uppercase; letter-spacing:1px; padding:0 16px 10px; }
.discover-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding:0 16px; margin-bottom:24px; }
.discover-card {
    background:var(--card-bg); border:1px solid var(--border); border-radius:20px;
    padding:18px 12px; text-align:center; cursor:pointer;
    transition:transform 0.15s,box-shadow 0.15s; box-shadow:0 3px 10px rgba(0,35,68,0.05);
}
.discover-card:active { transform:scale(0.95); box-shadow:none; }
.dc-icon { font-size:30px; margin-bottom:7px; }
.dc-title { font-size:13px; font-weight:800; color:var(--navy); }
.dc-sub { font-size:11px; color:var(--muted); margin-top:2px; }
.dc-badge { display:inline-block; margin-top:4px; font-size:9px; font-weight:900; padding:2px 7px; border-radius:8px; background:#22c55e; color:#fff; }

/* ============================================================
