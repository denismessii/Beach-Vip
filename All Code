        /**
         * Reads persisted social messages from localStorage and appends them to
         * the Social feed container.
         *
         * Security: All message fields (`text`, `grid`, `time`) pass through
         * `sanitize()` before injection into innerHTML. While localStorage is
         * same-origin, data written by future code paths could carry untrusted
         * content; sanitisation here provides defence-in-depth.
         *
         * Storage cap: only the latest 20 messages are kept (applied on write).
         */
        function loadSocialMessages() {
            let stored = [];
            try {
                stored = JSON.parse(localStorage.getItem(SOCIAL_STORAGE_KEY) || '[]');
                if (!Array.isArray(stored)) stored = [];
            } catch(e) {
                Logger.warn('loadSocialMessages: failed to parse stored messages', e.message);
            }
            const container = document.getElementById('social-messages');
            if (!container) return;
            stored.forEach(msg => {
                const div = document.createElement('div');
                div.className = 'chat-msg mine';
                // sanitize() prevents XSS from any future code path that stores
                // user-supplied text into SOCIAL_STORAGE_KEY without escaping.
                div.innerHTML = '<div class="chat-bubble">' + sanitize(msg.text)
                    + '</div><div class="chat-meta">'
                    + sanitize(msg.grid) + ' · ' + sanitize(msg.time) + '</div>';
                container.appendChild(div);
            });
            container.scrollTop = container.scrollHeight;
