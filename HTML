        <!-- ═══════════════════════════════════════════════════════════════
             SECURITY HEADERS — Enterprise browser-enforced controls
             Note: these meta-tag equivalents are honoured by all modern
             browsers. Definitive server-sent headers must be set at the
             reverse-proxy / CDN layer (Cloudflare, nginx) in production.
             ═══════════════════════════════════════════════════════════════ -->

        <!-- Content Security Policy
             Principle of least privilege: each directive whitelists only the
             origins this app actually needs. 'unsafe-inline' in script-src is
             required by the current architecture (inline onclick= handlers and
             the theme-detection inline script). Removal requires a Phase 2
             refactor to addEventListener-only event binding.
             'upgrade-insecure-requests' forces all http:// sub-resources to
             https:// automatically, protecting mixed-content scenarios. -->
        <meta http-equiv="Content-Security-Policy" content="
            default-src 'none';
            script-src 'self' 'unsafe-inline'
                https://unpkg.com
                https://www.youtube.com https://www.youtube-nocookie.com
                https://accounts.google.com;
            style-src 'self' 'unsafe-inline'
                https://fonts.googleapis.com
                https://unpkg.com;
            img-src 'self' data: blob:
                https://i.postimg.cc
                https://m.media-amazon.com
                https://*.tile.openstreetmap.org
                https://c4.wallpaperflare.com
                https://beachconcierge.ae;
            font-src 'self' https://fonts.gstatic.com;
            connect-src 'self'
                https://api.open-meteo.com
                https://marine-api.open-meteo.com
                https://nominatim.openstreetmap.org
                https://ipapi.co
                https://beachconcierge.ae;
            frame-src https://www.youtube.com https://www.youtube-nocookie.com;
            media-src 'self' blob:;
            object-src 'none';
            base-uri 'self';
            form-action 'self';
            upgrade-insecure-requests;
        " />

        <!-- Prevents MIME-type sniffing attacks (e.g. serving a JS file
             disguised as an image and having it executed as script). -->
        <meta http-equiv="X-Content-Type-Options" content="nosniff" />

        <!-- X-Frame-Options: DENY is the clickjacking defence.
             NOTE: browsers require this as an HTTP response header — the
             meta-tag form is ignored. This tag documents intent; the
             authoritative enforcement must be set at the Cloudflare / nginx
             layer in production:
               add_header X-Frame-Options "DENY" always;
             The CSP frame-ancestors directive below achieves the same effect
             in CSP Level 2+ browsers and is honoured as a meta tag. -->
        <!-- meta http-equiv="X-Frame-Options" content="DENY" /-->

        <!-- Limits the Referer header sent on cross-origin navigation so
             the full URL path is never leaked to third-party domains. -->
        <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />

        <!-- Permissions Policy: grant camera/mic/geo (used for tan scanner,
             noise monitor, delivery tracking) and explicitly deny payment
