        // Patch the GPS success callback by wrapping navigator.geolocation.watchPosition
        const _origWatch = navigator.geolocation.watchPosition.bind(navigator.geolocation);
        navigator.geolocation.watchPosition = function(success, error, opts) {
            return _origWatch(function(pos) {
