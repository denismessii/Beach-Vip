                 * Fires SecurityLogger.rateLimitExceeded on the first rejected call.
                 * @param {string} action
                 * @returns {boolean}
                 */
                check(action) {
                    const now  = Date.now();
                    const prev = (_windows.get(action) || []).filter(t => now - t < windowMs);
                    if (prev.length >= maxAttempts) {
                        SecurityLogger.rateLimitExceeded(action, maxAttempts, windowMs);
                        return false;
                    }
                    prev.push(now);
                    _windows.set(action, prev);
                    SecurityLogger.checkpoint(action);
                    return true;
