        // =================================================================
        // ██████  GRID MATRIX SYSTEM
        // =================================================================
        // JBR/Dubai beach reference origin (approx SW corner of service zone)
        const GRID_ORIGIN_LAT = 25.068;
        const GRID_ORIGIN_LNG = 55.124;
        const GRID_CELL_M = 3; // 3m cells
        const GRID_LAT_DEG = GRID_CELL_M / 111320;  // degrees per 3m
        const GRID_LNG_DEG = GRID_CELL_M / (111320 * Math.cos(25.07 * Math.PI / 180));

        function calcGridId(lat, lng) {
            const dLat = lat - GRID_ORIGIN_LAT;
            const dLng = lng - GRID_ORIGIN_LNG;
            const row  = Math.max(0, Math.floor(dLat / GRID_LAT_DEG));
            const col  = Math.max(0, Math.floor(dLng / GRID_LNG_DEG));
            const colLetter = String.fromCharCode(65 + (col % 26));
            return 'BEACH-' + colLetter + (row + 1);
        }

        let _currentGridId = 'BEACH-??';
        function updateGridBadge(lat, lng, acc) {
            _currentGridId = calcGridId(lat, lng);
            const badgeEl = document.getElementById('grid-badge');
            const valEl   = document.getElementById('grid-id-val');
